# scripts/smoke.local.env.example
#
# Per-developer / per-Mac local config for smoke-testing dvai-bridge
# against real GGUF models locally (without going through GitHub
# Actions secrets).
#
# Setup:
#   1. Copy this file to scripts/smoke.local.env (gitignored).
#   2. Fill in your URLs + sha256s.
#   3. mac-side-test.sh sources it automatically and forwards each
#      SMOKE_* var into the iOS Simulator's xctest process via
#      xcodebuild's `TEST_RUNNER_<NAME>=<VAL>` build-setting
#      convention — at runtime the prefix is stripped, so test code
#      reads `ProcessInfo.processInfo.environment["SMOKE_MODEL_URL"]`
#      unchanged. (The earlier SIMCTL_CHILD_* channel only reaches
#      XCUITest runners, not unit-test bundles, so it was abandoned.)
#
# These values are NOT secret — they are public HuggingFace URLs and
# sha256s of public model files. They live in this gitignored file
# only because they are per-developer / per-Mac configuration.
#
# CI workflow (.github/workflows/smoke-real-models.yml) reads the
# same names from GitHub Actions repository secrets directly and
# injects them via the same TEST_RUNNER_<NAME> mechanism; no file is
# involved there.

# Tier 1 — text-only smoke (used by RealModelSmokeTest.testSmokeRealModelEndToEnd).
# Recommended: Llama-3.2-1B-Instruct Q4_K_M (~770 MB).
SMOKE_MODEL_URL=
SMOKE_MODEL_SHA256=

# Tier 2 — vision + audio smoke (used by testSmokeVisionEndToEnd /
# testSmokeAudioEndToEnd; both share the same model + mmproj pair).
# Recommended: a Gemma-4 variant with paired mmproj that ships both
# vision and audio projectors — e.g. unsloth/gemma-4-E2B-it Q4_K_M
# (~3 GB main model + ~850 MB mmproj). The audio test skips cleanly
# via XCTSkip when the loaded mmproj has no audio encoder.
SMOKE_VISION_MODEL_URL=
SMOKE_VISION_MODEL_SHA256=
SMOKE_VISION_MMPROJ_URL=
SMOKE_VISION_MMPROJ_SHA256=

# Tier 3 — CoreML integration (Phase 3C).
#
# The test downloads the .mlmodelc/ directory file-by-file from a public
# HuggingFace mirror. No zip + unzip dance, no `Process` requirement, so
# the test runs on iOS Simulator + macOS native + Mac Catalyst alike.
# No HF token needed (the default reference repo is public and bundles
# its own tokenizer.json + tokenizer_config.json).
#
# BASE_URL must look like
#   https://huggingface.co/<owner>/<repo>/resolve/<branch-or-rev>
# and the repo at that URL must contain exactly one *.mlmodelc/ directory
# at the top level. The test queries the HF API to discover the actual
# directory name (so it works for any future Llama-style stateful CoreML
# checkpoint, not just this one).
#
# Originally pointed at apple/coreml-Llama-3.2-1B-Instruct-4bit, but Apple
# removed that repo from HuggingFace mid-Phase-3C. The finnvoorhees fork
# below is a community-maintained mirror of the same checkpoint.
SMOKE_COREML_MODEL_BASE_URL=https://huggingface.co/finnvoorhees/coreml-Llama-3.2-1B-Instruct-4bit/resolve/main

# Optional — only needed if you point SMOKE_COREML_MODEL_BASE_URL at a
# gated repo (the default finnvoorhees fork is public). Same token also
# applies to gated meta-llama tokenizer downloads if you swap in a model
# repo without bundled tokenizer files.
SMOKE_HF_TOKEN=
