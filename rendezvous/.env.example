# dvai-bridge rendezvous server — config via env vars.
# Copy to `.env` for local dev; configure in your hosting platform's
# dashboard for production deploys.

# Bind address. Most platforms set this for you; defaults are fine.
PORT=8080
HOST=0.0.0.0

# Public URL the server is reachable at. The library uses this in QR
# payloads so target devices know where to connect. Set this to match
# your deployed URL (e.g. wss://rendezvous.myapp.com). For local dev,
# leave it as ws://localhost:8080.
RENDEZVOUS_URL=ws://localhost:8080

# How long a pairing session stays alive after the last activity.
# 60 seconds is plenty for the QR-scan + handshake flow plus a few
# minutes of inference. Tune up if your users do long batch jobs.
SESSION_TTL_SECONDS=60

# Hard cap on concurrent sessions. The 256-MB tier of any major
# host handles ~10k easily; raise if you've sized up.
MAX_SESSIONS=10000

# Log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# CORS allowlist for the WS upgrade. Use "*" during testing; restrict
# to your app's origin(s) in production. Comma-separated.
ALLOWED_ORIGINS=*

# Set to 1 to expose Prometheus-format /metrics endpoint.
METRICS_ENABLED=0
