{
  "name": "dvai-bridge-rendezvous",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable WebSocket relay for dvai-bridge's QR-pairing + cross-network device offload (v3.0). Stateless beyond per-session memory; no database; no auth.",
  "license": "Custom (See ../LICENSE)",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "smoke": "bash scripts/smoke.sh",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/websocket": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
