# Xcode + SwiftPM build output — disposable, regenerated on every build
packages/*/ios/build/
packages/*/ios/.build/

# Swift Package Manager lockfile — for a library, consumers resolve their own
packages/*/ios/Package.resolved

# Android Gradle build output — disposable, regenerated on every build
packages/*/android/.gradle/
packages/*/android/build/
packages/*/android/local.properties
# `.cxx/` is the AGP-9 NDK build dir; Phase 2 Task 3 surfaced it because
# llama-core triggers a clean compile when the example apps publish to
# mavenLocal on a fresh host.
packages/*/android/.cxx/

# Example-app Gradle output (Phase 2 examples matrix).
examples/*/.gradle/
examples/*/build/
examples/*/app/build/
examples/*/app/.cxx/
examples/*/local.properties
examples/*/.idea/

# Marketing scripts + blog drafts — private, not for the public repo
docs/marketing/

# Per-developer publishing checklist — not for the public repo (contains
# tokens, manual gotchas, and registry-specific quirks the user maintains).
PUBLISHING.md

# Rendezvous-server referral-link setup — private, contains the project
# owner's affiliate codes for the one-click deploy buttons. Do NOT commit.
RENDEZVOUS-REFERRALS.md

# CocoaPods — pod install / pod lib lint output (per-developer, regenerated)
**/Pods/

# Xcode build output — DerivedData (with custom -derivedDataPath inside repo)
# and per-user state inside .xcodeproj bundles
**/DerivedData/
**/xcuserdata/
*.xcuserstate

# llama.cpp xcframework build output — allowed for CocoaPods release
# packages/*/android/src/main/cpp/native/*/build-apple/

# Pod-local copy of the xcframeworks — created by DVAIBridge.podspec's
# prepare_command (and removed on pod cache clean). Source of truth lives
# under build-apple/ above; this is just a CocoaPods-friendly mirror.
packages/dvai-bridge-ios/Frameworks/

# Pod-local mirror of sibling *-core source dirs — populated by
# DVAIBridge.podspec's prepare_command. Source of truth lives in the
# real *-core packages.
packages/dvai-bridge-ios/Sources/_external/

# Android Studio / IntelliJ — per-developer
.idea/
*.iml
experiments/mlc-perf-spike/

