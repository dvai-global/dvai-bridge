{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@dvai-edge/core": ["packages/dvai-edge-core/src/index.ts"],
      "@dvai-edge/react": ["packages/dvai-edge-react/src/index.tsx"],
      "@dvai-edge/vanilla": ["packages/dvai-edge-vanilla/src/index.ts"]
    }
  },
  "exclude": ["**/node_modules", "**/dist"]
}
