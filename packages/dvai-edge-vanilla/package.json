{
  "name": "@dvai-edge/vanilla",
  "version": "1.4.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Vanilla JS wrapper for @dvai-edge/core",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "unpkg": "dist/index.global.js",
  "jsdelivr": "dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ai",
    "local",
    "vanilla",
    "edge"
  ],
  "author": "Deep Chakraborty <https://github.com/dk013>",
  "license": "Custom (See LICENSE)",
  "repository": {
    "type": "git",
    "url": "https://github.com/westenets/dvai-edge.git"
  },
  "dependencies": {
    "@dvai-edge/core": "workspace:*"
  }
}
