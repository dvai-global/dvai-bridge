<Project>
  <!--
    Repo-wide MSBuild defaults for the DVAIBridge .NET NuGet family.
    Inherited by every csproj under packages/dvai-bridge-dotnet/.
    Version is bumped in lockstep by scripts/sync-versions.js (Task 14).
  -->
  <PropertyGroup>
    <Version>4.0.0</Version>
    <Authors>Deep Voice AI</Authors>
    <Company>Deep Voice AI</Company>
    <Copyright>Copyright (c) 2026 Deep Voice AI</Copyright>
    <PackageProjectUrl>https://github.com/dvai-global/dvai-bridge</PackageProjectUrl>
    <RepositoryUrl>https://github.com/dvai-global/dvai-bridge.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <!--
      Custom license (DVAI Bridge Community Licence v1.0) — NOT an SPDX
      identifier, so we ship the canonical LICENSE file (repo root)
      inside every .nupkg via <PackageLicenseFile>. The canonical file
      lives at the monorepo root so that Maven Central, npm, CocoaPods
      and NuGet all reference the same license bytes — keep them in sync
      by editing only `<repo>/LICENSE`.
    -->
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <!--
      Shared package-page README. Resolves to packages/dvai-bridge-dotnet/README.md
      via $(MSBuildThisFileDirectory) so every SDK-packed csproj that
      inherits this Directory.Build.props uses the same .NET-flavoured
      README on its NuGet.org page. The hand-written DVAIBridge facade
      nuspec already has its own `<readme>README.md</readme>` line and
      file entry — but the path matches, so they stay in sync.
    -->
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!--
      CS1591 = "missing xmldoc on public member" — silenced for tests + binding shims;
      facade csproj re-enables it via <NoWarn /> override (Task 2).
    -->
    <NoWarn>$(NoWarn);1591</NoWarn>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <DebugType>portable</DebugType>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <IncludeSymbols>true</IncludeSymbols>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Bundle the canonical repo-root LICENSE at the .nupkg root (where
      NuGet's license viewer looks for it). Resolved relative to this
      Directory.Build.props -> ../../LICENSE = repo root.
    -->
    <None Include="$(MSBuildThisFileDirectory)..\..\LICENSE" Pack="true" PackagePath="\" />
    <!--
      Bundle the .NET-flavoured README at the .nupkg root for the package
      page on NuGet.org. Referenced via <PackageReadmeFile> above. Lives
      at packages/dvai-bridge-dotnet/README.md, sibling to this file.
    -->
    <None Include="$(MSBuildThisFileDirectory)README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
