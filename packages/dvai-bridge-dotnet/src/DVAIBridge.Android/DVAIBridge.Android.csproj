<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Android binding library. Wraps the Phase 3D `co.deepvoiceai:dvai-bridge`
    AAR via Microsoft's Java/Kotlin binding generator (class-parse +
    XAJavaInterop1).

    The AAR is fetched from Maven Central by CI before `dotnet build`
    runs (see .github/workflows/test-dotnet.yml Task 13). It's gitignored
    so we don't pin a binary to the repo. The fetched filename is
    `native/dvai-bridge-$(Version).aar` — auto-tracks the repo version
    set in Directory.Build.props.

    `Transforms/Metadata.xml` rewrites Kotlin's `suspend fun(continuation)`
    surface to idiomatic C# `Task<T>`-returning methods, and renames the
    bound `co.deepvoiceai.bridge.DVAIBridge` Kotlin object to
    `Co.Deepvoiceai.Bridge.NativeDVAIBridge` to avoid colliding with the
    facade's public C# class name `DVAIBridge`.

    TFM `net10.0-android36.0` matches the .NET 10 default Android API. The
    runtime floor is API 24 — same as the Phase 3D AAR.
  -->

  <PropertyGroup>
    <TargetFramework>net10.0-android36.0</TargetFramework>
    <SupportedOSPlatformVersion>24</SupportedOSPlatformVersion>
    <IsBindingProject>true</IsBindingProject>
    <AndroidClassParser>class-parse</AndroidClassParser>
    <AndroidCodegenTarget>XAJavaInterop1</AndroidCodegenTarget>
    <PackageId>DVAIBridge.Android</PackageId>
    <Title>DVAIBridge.Android — Android native bindings (internal slice)</Title>
    <Description>Android native bindings for DVAIBridge — internal slice of the DVAIBridge NuGet family. Pulled in transitively by DVAIBridge when targeting net10.0-android. Consumers should depend on DVAIBridge directly. The underlying co.deepvoiceai:dvai-bridge AAR is fetched from Maven Central at consumer build time (NOT bundled in this NuGet); see docs/guide/dotnet-sdk.md for the consumer-side configuration.</Description>
    <PackageTags>llm;ai;android;binding;internal;dvai-bridge</PackageTags>
    <RootNamespace>DVAIBridge.Android</RootNamespace>
    <AssemblyName>DVAIBridge.Android</AssemblyName>
    <!--
      Toggle the AndroidNativeBridge implementation on once the AAR is
      fetched and the binding generator has produced clean Native.* types.
      The CI workflow turns this on after the AAR-fetch step; local dev
      can override per-build with `dotnet build -p:BindingsGenerated=true`.
    -->
    <DefineConstants Condition="'$(BindingsGenerated)' == 'true'">$(DefineConstants);BINDINGS_GENERATED</DefineConstants>
    <!--
      Suppress warnings the Java/Kotlin binding generator emits into the
      auto-generated wrappers under obj/Release/.../generated/src/. We can't
      hand-edit those files; the warnings are inherent to how class-parse
      shapes Kotlin sealed-class hierarchies into C# nested classes that
      each shadow the parent's static `_members` field. Repo-wide
      TreatWarningsAsErrors=true would otherwise break the build.

        CS0108  — "_members hides inherited member" on sealed-class nested
                  subclasses (DVAIBridgeError.AlreadyStarted etc.).
        BG8401  — "Skipping due to a duplicate nested type name" for
                  inner Companion classes; suppressed in Transforms/Metadata.xml
                  via remove-node so this only fires on edge cases.
        BG8605  — "The Java type X could not be found" for residual
                  kotlinx.coroutines.flow.SharedFlow / StateFlow getters
                  we don't surface (only the dvai-bridge Companion-class
                  references are dropped — none of the suspend-fun methods).
        BG8606  — "Some types or members could not be bound" summary follow-up
                  to BG8605; same suppression rationale.
        BG8A00  — "Metadata.xml element matched no nodes" for defensive
                  remove-node rules that handle multiple AAR shapes.
        BG8403  — "Type X has a type name which matches the enclosing
                  namespace name" — fires on
                  CO.Deepvoiceai.Bridge.Shared.Core.Pairing.Pairing from
                  the transitive shared-core AAR; consumers don't see this
                  type (it's the offload pairing handshake helper). Renaming
                  it would require a shared-core release with a Metadata.xml
                  rewrite at the source AAR — out of scope.
    -->
    <NoWarn>$(NoWarn);CS0108;BG8401;BG8403;BG8605;BG8606;BG8A00</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!--
      AAR fetched by CI from Maven Central before build (no auth needed):
        curl -L \
          "https://repo1.maven.org/maven2/co/deepvoiceai/dvai-bridge/$(Version)/dvai-bridge-$(Version).aar" \
          -o native/dvai-bridge-$(Version).aar
      Bind=true tells the binding generator to emit C# wrappers from the
      AAR's classes.jar.

      The path uses $(Version) so a repo-wide version bump in
      Directory.Build.props auto-propagates here without needing a sync
      script. Local builds without the AAR fetched will skip the
      AndroidLibrary item via the Condition (Exists check) — the binding
      shim in AndroidNativeBridge.cs gracefully falls back to managed-only
      mode under that condition (BINDINGS_GENERATED define guards the
      AAR-bound surface).
    -->
    <AndroidLibrary Include="native\dvai-bridge-$(Version).aar"
                    Condition="Exists('native\dvai-bridge-$(Version).aar')">
      <Bind>true</Bind>
    </AndroidLibrary>
    <!--
      android-shared-core supplies CorsConfig + OffloadConfig (referenced by
      StartOptions' all-positional constructor). Without it visible to
      class-parse, the binding generator drops the 22-arg constructor and
      the SharedFlow getters, leaving us with a no-op no-arg StartOptions
      that can't have any field set. Bind=false would be ideal (we don't
      want a duplicate C# surface for shared-core types — they bind through
      the Maven Central transitive graph at consumer-build time), but
      Microsoft's .NET 10 binding generator still emits wrappers; CS0108
      from the resulting nested-class _members shadowing is suppressed via
      <NoWarn> below.
    -->
    <AndroidLibrary Include="native\android-shared-core-$(Version).aar"
                    Condition="Exists('native\android-shared-core-$(Version).aar')">
      <Bind>false</Bind>
      <!--
        AndroidLibrary's default pack path bundles the AAR at
        lib/net10.0-android36.0/. Stop the .nuspec packer from ALSO trying
        to pick it up (NU5118 duplicate-add otherwise — fatal under the
        repo-wide TreatWarningsAsErrors).
      -->
      <Pack>false</Pack>
    </AndroidLibrary>
    <!--
      A trimmed kotlin-coroutines reference jar containing just the four classes
      class-parse needs to resolve the AAR's `suspend fun` Continuation
      parameter type: kotlin.coroutines.Continuation, kotlin.coroutines.CoroutineContext,
      kotlin.coroutines.EmptyCoroutineContext, kotlin.Result (+ Result$Failure /
      Result$Companion / Unit). Built by stripping the rest out of
      kotlin-stdlib-2.3.21.jar via `jar` — the full stdlib explodes the binding
      surface with 600+ types we don't want to expose. Kept as a plain .jar
      (not .aar) — it contains no Android resources. The corresponding Kotlin
      runtime types come from the consumer app's kotlin-stdlib dep at
      runtime via the Maven Central transitive graph.
    -->
    <AndroidJavaLibrary Include="native\kotlin-coroutines-min.jar"
                        Condition="Exists('native\kotlin-coroutines-min.jar')">
      <Bind>false</Bind>
      <!--
        Class-parse reference only — kept out of the NuGet by AndroidJavaLibrary's
        default Pack=false behaviour (AAR-class .jars are treated as build-time
        Java refs, not packaged Java libs). The consumer app's kotlin-stdlib
        dep (transitively from co.deepvoiceai:dvai-bridge:4.0.0) supplies the
        runtime classes.
      -->
    </AndroidJavaLibrary>
    <TransformFile Include="Transforms\Metadata.xml"
                   Condition="Exists('Transforms\Metadata.xml')" />
    <TransformFile Include="Transforms\EnumFields.xml"
                   Condition="Exists('Transforms\EnumFields.xml')" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Compile-time reference to the facade for the public types we marshal
      to/from (BoundServer, StartOptions, ProgressEvent, …). PrivateAssets=all
      stops this from becoming a transitive NuGet dependency on the facade —
      the facade's own .nuspec declares the TFM-conditional dep in the other
      direction, and we don't want a circular NuGet graph.
    -->
    <ProjectReference Include="..\DVAIBridge\DVAIBridge.csproj">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>compile;build</IncludeAssets>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All" />
  </ItemGroup>

</Project>
