<?xml version="1.0" encoding="utf-8"?>
<!--
  Hand-written .nuspec used by `dotnet pack` (referenced via the
  `NuspecFile` MSBuild property in DVAIBridge.csproj at pack time).

  Why hand-written rather than the SDK's auto-generated .nuspec?
  We need TFM-conditional <dependency> entries that point at the iOS /
  Android binding NuGets — and those NuGets aren't ProjectReferences
  (the facade project graph is acyclic by design). The auto-generated
  .nuspec from `dotnet pack` only carries deps from PackageReferences;
  it doesn't synthesize TFM-conditional NuGet deps from arbitrary
  project metadata.

  Tokens populated at pack time via `-p:Version=$(Version)` and
  `-p:NuspecProperties="..."`.
-->
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata minClientVersion="6.10">
    <id>DVAIBridge</id>
    <version>$version$</version>
    <title>DVAIBridge — local LLM bridge for .NET MAUI / Avalonia / WinUI</title>
    <authors>Deep Voice AI</authors>
    <owners>Deep Voice AI</owners>
    <!--
      Custom license (DVAI Bridge Community Licence v1.0) — shipped as a
      file inside the .nupkg, since it's not an SPDX identifier.
    -->
    <license type="file">LICENSE</license>
    <projectUrl>https://github.com/dvai-global/dvai-bridge</projectUrl>
    <repository type="git" url="https://github.com/dvai-global/dvai-bridge.git" />
    <description>Embeds an OpenAI-compatible HTTP server inside your .NET app process (127.0.0.1:38883, /v1/chat/completions, /v1/embeddings, /v1/models, SSE streaming). Any OpenAI client speaks to it — the OpenAI .NET SDK, Semantic Kernel, LangChain.NET, anything pointing a `baseUrl` at an HTTP endpoint. Why not Ollama / LM Studio / llama-server? Those are servers your END USERS install. DVAIBridge ships INSIDE your app's binary — `dotnet add package DVAIBridge`, build, run. Zero setup for the user. Cross-platform: net10.0 (Desktop) / net10.0-ios26.5 / net10.0-maccatalyst26.5 / net10.0-android36.0. Backends: llama.cpp (Metal / CUDA / Vulkan / DirectML), Apple Foundation Models, CoreML / ANE, MLX, MediaPipe LLM, LiteRT, ONNX Runtime GenAI, ML.NET — engine selected at runtime by device capability. Same OpenAI wire as the dvai-bridge family on iOS (CocoaPods), Android (Maven Central), Flutter (pub.dev), React Native + Capacitor + browser + Node (npm). One library, every client platform, identical request/response shapes. Reactive progress via IAsyncEnumerable&lt;ProgressEvent&gt;. Optional LAN-mDNS + self-hostable WebSocket rendezvous for transparent peer offload. Docs + architecture: https://bridge.deepvoiceai.co</description>
    <copyright>Copyright (c) 2026 Deep Voice AI</copyright>
    <tags>llm ai openai ios android maui avalonia winui local-inference llama-cpp mediapipe litert mlx coreml foundation-models</tags>
    <readme>README.md</readme>
    <dependencies>
      <!--
        Bare net10.0: desktop (Windows / Linux / macOS / Catalyst-as-desktop)
        consumers — WinUI 3 / Avalonia / MAUI desktop / console / server.
        Auto-pulls DVAIBridge.Desktop so BackendKind.Llama is available out
        of the box; the spec §4.2 trade-off table justifies auto-pull for
        Desktop (it's the platform default, not an opt-in alternate).
        ONNX / MLNet stay opt-in via explicit `dotnet add package`.
      -->
      <group targetFramework="net10.0">
        <dependency id="DVAIBridge.Desktop" version="[$version$]" />
      </group>
      <!-- iOS: pulls in the iOS binding NuGet (which bundles the xcframework). -->
      <group targetFramework="net10.0-ios26.5">
        <dependency id="DVAIBridge.iOS" version="[$version$]" />
      </group>
      <!--
        Mac Catalyst — restored in v4.0.1. The shared DVAIBridge.iOS
        NuGet ships the Catalyst slice in its xcframework now that
        scripts/mac-side-prepare-xcframework.sh builds a Catalyst pass.
        Same DVAIBridge.iOS NuGet covers both iOS and Mac Catalyst TFMs.
      -->
      <group targetFramework="net10.0-maccatalyst26.5">
        <dependency id="DVAIBridge.iOS" version="[$version$]" />
      </group>

      <!-- Android: pulls in the Android binding NuGet (consumer-build AAR fetch). -->
      <group targetFramework="net10.0-android36.0">
        <dependency id="DVAIBridge.Android" version="[$version$]" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="..\..\README.md" target="README.md" />
    <!--
      Bundled license file (referenced by <license type="file">LICENSE</license>
      above). Sibling Directory.Build.props can't inject into a hand-written
      nuspec's <files> block, so we re-declare it here. ..\..\..\..\LICENSE
      hops up to the monorepo root (src/DVAIBridge/ -> packages/dvai-bridge-dotnet/
      -> packages/ -> dvai-edge/), so we get the canonical Community Licence.
    -->
    <file src="..\..\..\..\LICENSE" target="LICENSE" />
    <file src="bin\Release\net10.0\DVAIBridge.dll" target="lib\net10.0\" />
    <file src="bin\Release\net10.0\DVAIBridge.xml" target="lib\net10.0\" />
    <!--
      .pdb shipped under each lib\ folder (not a separate .snupkg) because
      the SDK's snupkg generator can't build a symbols package from a
      hand-written nuspec — see NU5005. Embedded inside the .nupkg they
      still feed SourceLink for step-into-source debugging.
    -->
    <file src="bin\Release\net10.0\DVAIBridge.pdb" target="lib\net10.0\" />
    <!--
      Same facade DLL re-shipped under the platform TFM folders. NuGet's
      lib-resolver picks the most-specific match (`net10.0-ios26.5` over
      `net10.0`) and the NuGet dep group above pulls in the iOS slice
      transitively. Without this, restoring net10.0-ios26.5 would fall
      back to the bare net10.0 folder and miss the slice.
      `_._` would also work but most consumers prefer a real DLL match
      so reflection-loaded type lookup (PlatformBridgeFactory) Just Works.
    -->
    <file src="bin\Release\net10.0\DVAIBridge.dll" target="lib\net10.0-ios26.5\" />
    <file src="bin\Release\net10.0\DVAIBridge.xml" target="lib\net10.0-ios26.5\" />
    <file src="bin\Release\net10.0\DVAIBridge.pdb" target="lib\net10.0-ios26.5\" />
    <!-- Mac Catalyst TFM folders — restored in v4.0.1 alongside the
         maccatalyst dep group. NuGet's lib-resolver picks the most-
         specific match. -->
    <file src="bin\Release\net10.0\DVAIBridge.dll" target="lib\net10.0-maccatalyst26.5\" />
    <file src="bin\Release\net10.0\DVAIBridge.xml" target="lib\net10.0-maccatalyst26.5\" />
    <file src="bin\Release\net10.0\DVAIBridge.pdb" target="lib\net10.0-maccatalyst26.5\" />
    <file src="bin\Release\net10.0\DVAIBridge.dll" target="lib\net10.0-android36.0\" />
    <file src="bin\Release\net10.0\DVAIBridge.xml" target="lib\net10.0-android36.0\" />
    <file src="bin\Release\net10.0\DVAIBridge.pdb" target="lib\net10.0-android36.0\" />
  </files>
</package>
