<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Facade library — the primary public NuGet (`DVAIBridge` on NuGet.org).

    Single-target `net10.0` (no platform suffix). The iOS / Android binding
    csprojs hard-reference this facade — not the other way around — so we
    avoid a circular ProjectReference graph. The platform-specific
    INativeBridge implementations are resolved at runtime via
    `Type.GetType("DVAIBridge.iOS.IOSNativeBridge, DVAIBridge.iOS")` and
    `"DVAIBridge.Android.AndroidNativeBridge, DVAIBridge.Android"` (see
    PlatformBridgeFactory.cs); on platforms where the binding assembly
    isn't loaded the factory falls through to UnsupportedPlatformBridge,
    which throws DVAIBridgeException.BackendUnavailable on every call.

    The .nuspec we publish (generated by `dotnet pack`) declares
    TFM-conditional NuGet dependencies on DVAIBridge.iOS / .Android per
    spec §4.2, so a MAUI consumer's net10.0-ios26.2 leg automatically
    pulls in the iOS slice via the NuGet graph (not the project graph).
  -->

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>DVAIBridge</PackageId>
    <Title>DVAIBridge — local LLM bridge for .NET MAUI / Avalonia / WinUI</Title>
    <Description>Local-LLM bridge with OpenAI-compatible HTTP server for .NET MAUI, Avalonia, WinUI, and Xamarin (legacy) apps on iOS and Android. Wraps the DVAIBridge iOS + Android native SDKs behind an idiomatic C# API. Reactive progress via IAsyncEnumerable&lt;ProgressEvent&gt;. Backends: llama.cpp, Apple Foundation Models, CoreML/ANE, MLX, MediaPipe, LiteRT.</Description>
    <PackageTags>llm;ai;openai;ios;android;maui;avalonia;winui;local-inference;llama-cpp;mediapipe;litert;mlx;coreml;foundation-models</PackageTags>
    <RootNamespace>DVAIBridge</RootNamespace>
    <AssemblyName>DVAIBridge</AssemblyName>
    <!--
      The facade is the package consumers' primary entry-point — every public
      member must carry xmldoc. Re-enable CS1591 (silenced repo-wide in
      Directory.Build.props for binding shims and tests) by clearing NoWarn
      on this csproj. Setting NoWarn to an empty string overrides the
      Directory.Build.props default.
    -->
    <NoWarn />
    <WarningsNotAsErrors>$(WarningsNotAsErrors)</WarningsNotAsErrors>
    <!--
      Use the hand-written nuspec for TFM-conditional NuGet deps (see
      DVAIBridge.nuspec). The SDK pack target reads NuspecFile + NuspecProperties
      and stitches the version into the $version$ token at pack time.
    -->
    <NuspecFile>DVAIBridge.nuspec</NuspecFile>
    <NuspecProperties>version=$(Version)</NuspecProperties>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All" />
  </ItemGroup>

</Project>
