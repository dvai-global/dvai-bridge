# Build outputs
bin/
obj/
out/

# Visual Studio / IDE
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
.vshistory/

# NuGet packages — both produced artifacts and the local cache convention
# (NB: this is the in-package "packages/" folder, NOT the repo-root packages/ tree.)
*.nupkg
*.snupkg
packages/

# Test results
TestResults/
*.received.*
coverage/
*.coverage
*.coveragexml

# JetBrains Rider
.idea/

# Generated xcframework — built by CI from native/Sources/ before pack.
src/DVAIBridge.iOS/native/build/
src/DVAIBridge.iOS/native/*.xcframework
src/DVAIBridge.iOS/native/.build/

# Android AAR + class-parse reference jar — fetched by CI from Maven Central
# before bind (see .github/workflows/test-dotnet.yml's "Fetch DVAI Bridge AAR
# + shared-core AAR + kotlin-coroutines reference jar" step). The .jar is
# built CI-side by stripping kotlin-stdlib down to the ~10 Continuation classes
# class-parse needs.
src/DVAIBridge.Android/native/*.aar
src/DVAIBridge.Android/native/*.jar
