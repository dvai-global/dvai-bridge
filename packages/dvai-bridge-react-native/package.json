{
    "name":  "@dvai-bridge/react-native",
    "version":  "4.0.0",
    "publishConfig":  {
                          "registry":  "https://registry.npmjs.org/",
                          "access":  "public"
                      },
    "description":  "React Native TurboModule wrapping the @dvai-bridge/ios + @dvai-bridge/android native SDKs behind a shared TS API.",
    "main":  "lib/commonjs/index",
    "module":  "lib/module/index",
    "types":  "lib/typescript/commonjs/src/index.d.ts",
    "react-native":  "src/index",
    "source":  "src/index",
    "exports":  {
                    ".":  {
                              "import":  {
                                             "types":  "./lib/typescript/module/src/index.d.ts",
                                             "default":  "./lib/module/index.js"
                                         },
                              "require":  {
                                              "types":  "./lib/typescript/commonjs/src/index.d.ts",
                                              "default":  "./lib/commonjs/index.js"
                                          }
                          }
                },
    "files":  [
                  "android/src",
                  "android/build.gradle",
                  "android/gradle.properties",
                  "android/settings.gradle",
                  "README.md",
                  "LICENSE"
              ],
    "scripts":  {
                    "build":  "bob build",
                    "clean":  "del-cli lib",
                    "prepack":  "bob build",
                    "test":  "jest",
                    "typecheck":  "tsc --noEmit"
                },
    "keywords":  [
                     "dvai-bridge",
                     "react-native",
                     "turbomodule",
                     "llm",
                     "on-device",
                     "openai-compatible",
                     "llama-cpp",
                     "mediapipe",
                     "litert",
                     "mlx",
                     "coreml",
                     "foundation-models"
                 ],
    "author":  "Deep Chakraborty \u003chttps://github.com/dk013\u003e",
    "license":  "Custom (See LICENSE)",
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/westenets/dvai-bridge.git"
                   },
    "peerDependencies":  {
                             "react":  "\u003e=18.0.0",
                             "react-native":  "\u003e=0.77.0"
                         },
    "peerDependenciesMeta":  {
                                 "react":  {
                                               "optional":  false
                                           },
                                 "react-native":  {
                                                      "optional":  false
                                                  }
                             },
    "devDependencies":  {
                            "@babel/core":  "^7.29.0",
                            "@babel/preset-env":  "^7.29.5",
                            "@babel/preset-react":  "^7.28.5",
                            "@babel/preset-typescript":  "^7.28.5",
                            "@react-native/babel-preset":  "^0.85.3",
                            "@react-native/eslint-config":  "^0.85.3",
                            "@testing-library/react-native":  "^13.3.3",
                            "@types/jest":  "^30.0.0",
                            "@types/react":  "^19.2.14",
                            "babel-jest":  "^30.4.1",
                            "del-cli":  "^7.0.0",
                            "jest":  "^30.3.0",
                            "jest-environment-jsdom":  "^30.4.1",
                            "react":  "^19.2.5",
                            "react-native":  "^0.85.2",
                            "react-native-builder-bob":  "^0.41.0",
                            "react-test-renderer":  "^19.2.6",
                            "typescript":  "^6.0.3"
                        },
    "react-native-builder-bob":  {
                                     "source":  "src",
                                     "output":  "lib",
                                     "targets":  [
                                                     [
                                                         "commonjs",
                                                         {
                                                             "esm":  true
                                                         }
                                                     ],
                                                     [
                                                         "module",
                                                         {
                                                             "esm":  true
                                                         }
                                                     ],
                                                     [
                                                         "typescript",
                                                         {
                                                             "project":  "tsconfig.build.json"
                                                         }
                                                     ]
                                                 ]
                                 },
    "codegenConfig":  {
                          "name":  "RNDVAIBridgeSpec",
                          "type":  "modules",
                          "jsSrcsDir":  "src",
                          "android":  {
                                          "javaPackageName":  "co.deepvoiceai.bridge.rn"
                                      }
                      },
    "engines":  {
                    "node":  "\u003e=22"
                }
}
