{
    "name":  "@dvai-bridge/react",
    "version":  "4.0.0",
    "publishConfig":  {
                          "registry":  "https://registry.npmjs.org/",
                          "access":  "public"
                      },
    "description":  "React wrappers for @dvai-bridge/core",
    "main":  "dist/index.cjs",
    "module":  "dist/index.js",
    "types":  "dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js",
                              "require":  "./dist/index.cjs"
                          }
                },
    "type":  "module",
    "files":  [
                  "dist",
                  "README.md",
                  "LICENSE"
              ],
    "scripts":  {
                    "build":  "tsup",
                    "dev":  "tsup --watch",
                    "test":  "echo \"Error: no test specified\" \u0026\u0026 exit 1"
                },
    "keywords":  [
                     "ai",
                     "local",
                     "react",
                     "hooks",
                     "edge",
                     "bridge"
                 ],
    "author":  "Deep Chakraborty \u003chttps://github.com/dk013\u003e",
    "license":  "Custom (See LICENSE)",
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/dvai-global/dvai-bridge.git"
                   },
    "peerDependencies":  {
                             "react":  "^18.0.0 || ^19.0.0",
                             "react-dom":  "^18.0.0 || ^19.0.0"
                         },
    "dependencies":  {
                         "@dvai-bridge/core":  "workspace:*"
                     }
}
