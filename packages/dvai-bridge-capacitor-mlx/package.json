{
    "name":  "@dvai-bridge/capacitor-mlx",
    "version":  "4.0.0",
    "publishConfig":  {
                          "registry":  "https://registry.npmjs.org/",
                          "access":  "public"
                      },
    "description":  "DVAI-Bridge Capacitor plugin: MLX (Apple Silicon GPU/Neural Engine) LLM inference via mlx-swift-lm, with embedded HTTP server. iOS 17+ at link time; Apple-Silicon-only at runtime.",
    "main":  "dist/index.cjs",
    "module":  "dist/index.js",
    "types":  "dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js",
                              "require":  "./dist/index.cjs"
                          }
                },
    "type":  "module",
    "files":  [
                  "dist",
                  "ios/Sources",
                  "ios/Tests",
                  "ios/Package.swift",
                  "DVAICapacitorMLX.podspec",
                  "README.md",
                  "LICENSE"
              ],
    "scripts":  {
                    "build":  "tsup",
                    "mac:build":  "pwsh -File ../../scripts/mac-build.ps1 -Action build -Target capacitor-mlx",
                    "mac:test":  "pwsh -File ../../scripts/mac-build.ps1 -Action test -Target capacitor-mlx",
                    "prepare":  "pnpm run build"
                },
    "keywords":  [
                     "dvai-bridge",
                     "capacitor",
                     "mlx",
                     "apple-silicon",
                     "llm",
                     "on-device"
                 ],
    "author":  "Deep Chakraborty \u003chttps://github.com/dk013\u003e",
    "license":  "Custom (See LICENSE)",
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/dvai-global/dvai-bridge.git"
                   },
    "peerDependencies":  {
                             "@capacitor/core":  "^6.0.0 || ^7.0.0 || ^8.0.0",
                             "@dvai-bridge/capacitor":  "workspace:*",
                             "@dvai-bridge/ios-mlx-core":  "workspace:*"
                         },
    "devDependencies":  {
                            "@dvai-bridge/capacitor":  "workspace:*"
                        },
    "capacitor":  {
                      "ios":  {
                                  "src":  "ios"
                              }
                  }
}
