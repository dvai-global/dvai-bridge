{
  "name": "@dvai/dvai-edge-core",
  "version": "1.0.1",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Core JS logic for local WebLLM + MSW agent",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "type": "module",
  "bin": {
    "dvai-edge": "./bin/dvai-edge.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["ai", "local", "webllm", "msw"],
  "author": "Deep Chakraborty <https://github.com/dk013>",
  "license": "Custom (See LICENSE)",
  "repository": {
    "type": "git",
    "url": "https://github.com/westenets/dvai-edge.git"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.78",
    "msw": "^2.7.0"
  }
}
