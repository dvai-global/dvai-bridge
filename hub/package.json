{
  "name": "dvai-hub",
  "version": "3.1.0",
  "private": true,
  "description": "DVAI Hub — household-utility flavor of distributed inference. Run on a strong device; pair from any number of dvai-bridge mobile apps.",
  "license": "Custom (See ../LICENSE)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:peer-mode": "tsc -p peer-mode/tsconfig.json",
    "smoke:ollama": "node dist/scripts/smoke-ollama.js",
    "smoke:lmstudio": "node dist/scripts/smoke-lmstudio.js",
    "smoke:identity": "node dist/scripts/smoke-identity.js",
    "sidecar:dev": "node dist/peer-mode/server.js",
    "build:vite": "vite build",
    "dev:vite": "vite",
    "test": "vitest run",
    "lint": "eslint peer-mode tests src",
    "dev:tauri": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@dvai-bridge/core": "workspace:*",
    "@noble/curves": "^1.6.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-autostart": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
