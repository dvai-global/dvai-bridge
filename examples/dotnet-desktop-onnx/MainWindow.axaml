<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DvaiBridgeDesktopOnnx.MainWindow"
        Title="DVAIBridge — Desktop ONNX Runtime GenAI"
        Width="720" Height="560">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="10">

            <TextBlock Text="DVAIBridge — Desktop ONNX (Phi-3-mini)"
                       FontSize="22" FontWeight="Bold" />

            <TextBlock TextWrapping="Wrap"
                       Text="Loads a Microsoft ONNX GenAI bundle (directory containing genai_config.json + model.onnx + tokenizer.json) via the DVAIBridge.OnnxRuntime slice, and streams a chat completion through Microsoft.SemanticKernel pointed at the embedded Kestrel server." />

            <TextBlock Text="Model directory (ONNX GenAI bundle):" FontWeight="Bold" Margin="0,8,0,0" />
            <TextBox x:Name="ModelPathBox"
                     Watermark="C:\models\Phi-3-mini-4k-instruct-onnx\cpu-int4-rtn-block-32-acc-level-4" />

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="StartBtn" Content="Start bridge" Click="OnStart" />
                <Button x:Name="StopBtn" Content="Stop" IsEnabled="False" Click="OnStop" />
            </StackPanel>

            <TextBlock x:Name="StatusBlock" Text="Idle." FontSize="12" Foreground="Gray" />

            <TextBlock Text="Prompt:" FontWeight="Bold" Margin="0,8,0,0" />
            <TextBox x:Name="PromptBox"
                     Text="Summarise ONNX Runtime in one sentence."
                     AcceptsReturn="True"
                     Height="60" />

            <Button x:Name="SendBtn" Content="Send chat completion" IsEnabled="False" Click="OnSend" />

            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,8,0,0">
                <TextBlock x:Name="ResponseBlock" Text="(response will stream here)"
                           TextWrapping="Wrap" />
            </Border>

        </StackPanel>
    </ScrollViewer>

</Window>
