{
  "name": "react-native-app",
  "version": "0.0.0",
  "private": true,
  "description": "React Native 0.85+ example showing @dvai-bridge/react-native with a backend selector (Llama / Foundation / CoreML / MLX / MediaPipe / LiteRT) and OpenAI streaming via the openai-node SDK.",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output dist/index.android.bundle --assets-dest dist/android-assets",
    "smoke": "bash smoke.sh"
  },
  "dependencies": {
    "@dvai-bridge/react-native": "workspace:*",
    "@react-native/new-app-screen": "0.85.3",
    "openai": "^6.2.0",
    "react": "19.2.6",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "^5.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/codegen": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/gradle-plugin": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^30.4.2",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
